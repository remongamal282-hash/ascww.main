{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0, s-maxage=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/ssr?type=home&routeBase=/"
    },
    {
      "source": "/an-elsherka",
      "destination": "/api/ssr?type=home&routeBase=/an-elsherka"
    },
    {
      "source": "/news-company",
      "destination": "/api/ssr?type=home&routeBase=/news-company"
    },
    {
      "source": "/branch-of-company",
      "destination": "/api/ssr?type=home&routeBase=/branch-of-company"
    },
    {
      "source": "/projects-company",
      "destination": "/api/ssr?type=home&routeBase=/projects-company"
    },
    {
      "source": "/projects",
      "destination": "/api/ssr?type=home&routeBase=/projects"
    },
    {
      "source": "/vision-and-message",
      "destination": "/api/ssr?type=home&routeBase=/vision-and-message"
    },
    {
      "source": "/organization-structure",
      "destination": "/api/ssr?type=home&routeBase=/organization-structure"
    },
    {
      "source": "/contract-and-sell",
      "destination": "/api/ssr?type=home&routeBase=/contract-and-sell"
    },
    {
      "source": "/company-achivement",
      "destination": "/api/ssr?type=home&routeBase=/company-achivement"
    },
    {
      "source": "/adviceAndContact",
      "destination": "/api/ssr?type=home&routeBase=/adviceAndContact"
    },
    {
      "source": "/forKidsAndWomen",
      "destination": "/api/ssr?type=home&routeBase=/forKidsAndWomen"
    },
    {
      "source": "/water-quality",
      "destination": "/api/ssr?type=home&routeBase=/water-quality"
    },
    {
      "source": "/refining-water",
      "destination": "/api/ssr?type=home&routeBase=/refining-water"
    },
    {
      "source": "/lab-of-company-water",
      "destination": "/api/ssr?type=home&routeBase=/lab-of-company-water"
    },
    {
      "source": "/sewage-treatment",
      "destination": "/api/ssr?type=home&routeBase=/sewage-treatment"
    },
    {
      "source": "/Riddence-waste-water",
      "destination": "/api/ssr?type=home&routeBase=/Riddence-waste-water"
    },
    {
      "source": "/save-web-waste-water",
      "destination": "/api/ssr?type=home&routeBase=/save-web-waste-water"
    },
    {
      "source": "/manufactring-waste",
      "destination": "/api/ssr?type=home&routeBase=/manufactring-waste"
    },
    {
      "source": "/waste-water-in-manufactring",
      "destination": "/api/ssr?type=home&routeBase=/waste-water-in-manufactring"
    },
    {
      "source": "/forKids",
      "destination": "/api/ssr?type=home&routeBase=/forKidsAndWomen"
    },
    {
      "source": "/toWomen",
      "destination": "/api/ssr?type=home&routeBase=/forKidsAndWomen"
    },
    {
      "source": "/news/:id",
      "destination": "/api/ssr?type=news&routeBase=/news&id=:id"
    },
    {
      "source": "/news-company/:id",
      "destination": "/api/ssr?type=news&routeBase=/news-company&id=:id"
    },
    {
      "source": "/projects/:id",
      "destination": "/api/ssr?type=project&routeBase=/projects&id=:id"
    },
    {
      "source": "/projects-company/:id",
      "destination": "/api/ssr?type=project&routeBase=/projects-company&id=:id"
    },
    {
      "source": "/allTenders",
      "destination": "/api/ssr?type=tender&routeBase=/allTenders"
    },
    {
      "source": "/allTenders/:id",
      "destination": "/api/ssr?type=tender&routeBase=/allTenders&id=:id"
    },
    {
      "source": "/alltenders",
      "destination": "/api/ssr?type=tender&routeBase=/allTenders"
    },
    {
      "source": "/alltenders/:id",
      "destination": "/api/ssr?type=tender&routeBase=/allTenders&id=:id"
    },
    {
      "source": "/api/:path*",
      "destination": "https://backend.ascww.org/api/:path*"
    }
  ],
  "functions": {
    "api/ssr.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}

